# GEMINI_API_KEY: Required for Gemini AI Prescription Scanning.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_VISION_MODEL="gemini-2.5-flash-lite"

# OPENAI_API_KEY: Required for ChatGPT medical explanations.
# Configure this via the Secrets panel in the AI Studio UI list.
OPENAI_API_KEY="MY_OPENAI_API_KEY"
VITE_OPENAI_API_KEY="MY_OPENAI_API_KEY"
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"
VITE_GEMINI_VISION_MODEL="gemini-2.5-flash-lite"
VITE_OPENAI_CHAT_MODEL="gpt-4o-mini"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Optional backend deployment settings.
PORT="3000"
ALLOWED_ORIGINS="https://localhost,http://localhost:3000,http://localhost:5173"

# VITE_API_BASE_URL: Required for the packaged Android app if AI scan/chat
# APIs are hosted on a remote server, e.g. https://api.example.com
VITE_API_BASE_URL=""
