# GEMINI_API_KEY: Required for Gemini AI prescription scanning.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_VISION_MODEL="gemini-2.5-flash-lite"

# OPENAI_API_KEY: Required for MediBot chat.
OPENAI_API_KEY="MY_OPENAI_API_KEY"
VITE_OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_CHAT_MODEL="gpt-4o-mini"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Optional backend deployment settings.
PORT="3000"
ALLOWED_ORIGINS="https://localhost,http://localhost:3000,http://localhost:5173"

# VITE_API_BASE_URL: Required for the packaged Android app.
# Use the Cloudflare Worker URL after deploying, for example:
# VITE_API_BASE_URL="https://api.medimait-api.workers.dev"
VITE_API_BASE_URL=""
